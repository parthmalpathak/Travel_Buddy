# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Maps — enable Maps JS API, Directions API, Places API in GCP console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Public URL of this app — used to build absolute share links.
# Local dev: http://localhost:3000
# Production: your real domain, e.g. https://thejourney.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — transactional email (welcome email, journey invite email).
# Get an API key at https://resend.com/api-keys. Without it, emails are
# silently skipped (logged to console) rather than blocking sign-in/invites.
RESEND_API_KEY=your-resend-api-key

# Sender shown on outgoing email. Until you verify a custom domain in Resend,
# you must use their sandbox sender below, and it can only deliver to the
# email address on your own Resend account — not to arbitrary recipients.
RESEND_FROM_EMAIL="The Journey <onboarding@resend.dev>"
